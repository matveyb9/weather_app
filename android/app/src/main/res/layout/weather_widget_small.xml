<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Refresh button — top-right corner -->
    <ImageView
        android:id="@+id/widget_small_refresh"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:src="@drawable/ic_refresh"
        android:alpha="0.55"
        android:padding="4dp"
        android:scaleType="fitCenter" />

    <!-- Weather icon -->
    <ImageView
        android:id="@+id/widget_small_emoji"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_weather_sunny"
        android:scaleType="fitCenter" />

    <!-- Right block: temp + city + description -->
    <LinearLayout
        android:id="@+id/widget_small_right"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_small_emoji"
        android:layout_toStartOf="@id/widget_small_refresh"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_small_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_small_city"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCE3F2FF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_small_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#99FFFFFF"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Updated-at timestamp -->
    <TextView
        android:id="@+id/widget_small_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:text=""
        android:textColor="#55FFFFFF"
        android:textSize="9sp" />

</RelativeLayout>
