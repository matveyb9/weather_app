#include "resource.h"

// Application icon
IDI_APP_ICON ICON "resources\\app_icon.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @FLUTTER_VERSION_MAJOR@,@FLUTTER_VERSION_MINOR@,@FLUTTER_VERSION_PATCH@,@FLUTTER_VERSION_BUILD@
 PRODUCTVERSION @FLUTTER_VERSION_MAJOR@,@FLUTTER_VERSION_MINOR@,@FLUTTER_VERSION_PATCH@,@FLUTTER_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904e4"
        BEGIN
            VALUE "CompanyName", "Weather App" "\0"
            VALUE "FileDescription", "Погода — прогноз погоды" "\0"
            VALUE "FileVersion", "@FLUTTER_VERSION@" "\0"
            VALUE "InternalName", "weather_app" "\0"
            VALUE "LegalCopyright", "Copyright (C) 2024 Weather App. All rights reserved." "\0"
            VALUE "OriginalFilename", "weather_app.exe" "\0"
            VALUE "ProductName", "Погода" "\0"
            VALUE "ProductVersion", "@FLUTTER_VERSION@" "\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x419, 1251
    END
END
